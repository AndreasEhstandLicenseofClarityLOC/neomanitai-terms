    <skos:prefLabel xml:lang="en">Bond E</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Bond E</skos:prefLabel>
    <skos:definition xml:lang="en">May describe phenomena in bond domain.</skos:definition>
