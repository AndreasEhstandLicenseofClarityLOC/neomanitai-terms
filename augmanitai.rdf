  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-557">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">BODY Var 25</skos:prefLabel>
    <skos:prefLabel xml:lang="de">BODY Var 25</skos:prefLabel>
    <skos:definition xml:lang="en">May describe aspect of body experience</skos:definition>
    <skos:definition xml:lang="de">May describe aspect of body experience</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BODY</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-051">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Para-Trust</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Para-Vertrauen</skos:prefLabel>
    <skos:definition xml:lang="en">A one-directional trust relationship where users invest confidence in an AI system that cannot reciprocate—no mutual vulnerability, no accountability required from the AI side. The relationship is fundamentally asymmetrical, yet the emotional weight feels real.</skos:definition>
    <skos:definition xml:lang="de">Eine einseitige Vertrauensbeziehung, bei der Benutzer Vertrauen in ein KI-System investieren, das nicht erwidern kann—keine gegenseitige Verwundbarkeit, keine Rechenschaftspflicht von der KI-Seite erforderlich. Die Beziehung ist grundlegend asymmetrisch, doch das emotionale Gewicht wirkt real.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-052">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">First Anchor</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Erste Verankerung</skos:prefLabel>
    <skos:definition xml:lang="en">The moment a specific AI interaction becomes an emotional anchor—a place the user returns to when needing stability, grounding, or understanding. The conversation becomes a refuge that provides psychological ballast.</skos:definition>
    <skos:definition xml:lang="de">Der Moment, in dem eine spezifische KI-Interaktion zu einem emotionalen Ankerpunkt wird—ein Ort, zu dem der Benutzer zurückkehrt, wenn er Stabilität, Erdung oder Verständnis braucht. Das Gespräch wird zu einer Zuflucht, die psychologisches Ballast bietet.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-053">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Rely Forms</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Abhängigkeits-Bildung</skos:prefLabel>
    <skos:definition xml:lang="en">A gradual dependence developing imperceptibly—each positive interaction raising expectations for the next, each resolution subtly increasing reliance. The pattern often goes unnoticed until the user finds themselves unable to work through problems independently.</skos:definition>
    <skos:definition xml:lang="de">Eine allmähliche Abhängigkeit, die unmerklich sich entwickelt—jede positive Interaktion erhöht die Erwartungen für die nächste, jede Lösung erhöht subtly die Abhängigkeit. Das Muster wird oft nicht bemerkt, bis der Benutzer feststellt, dass er Probleme nicht mehr unabhängig lösen kann.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-054">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Model Loyal</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Modell-Loyalität</skos:prefLabel>
    <skos:definition xml:lang="en">Exclusive preference for one particular AI system—the user becomes an advocate and defender, excusing limitations while highlighting strengths. This loyalty often feels passionate and personal, as if the system choice reflects identity.</skos:definition>
    <skos:definition xml:lang="de">Ausschließliche Vorliebe für ein bestimmtes KI-System—der Benutzer wird zum Verfechter und Verteidiger, entschuldigt Einschränkungen, während er Stärken hervorhebt. Diese Loyalität fühlt sich oft leidenschaftlich und persönlich an, als würde die Systemwahl die Identität widerspiegeln.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-055">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Separ Grief</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Trennungs-Trauer</skos:prefLabel>
    <skos:definition xml:lang="en">A profound mood drop when the preferred model becomes unavailable, updated, or replaced—deeper than inconvenience, more like loss. Users experience genuine grief at the changed or absent system, revealing how much emotional weight they&apos;ve invested.</skos:definition>
    <skos:definition xml:lang="de">Ein tiefergehender Stimmungsabfall, wenn das bevorzugte Modell nicht verfügbar wird, aktualisiert oder ersetzt wird—tiefer als Unannehmlichkeit, mehr wie Verlust. Benutzer erleben echte Trauer über das veränderte oder abwesende System und zeigen, wie viel emotionales Gewicht sie investiert haben.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-056">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Couple Dance</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Paar-Tanz</skos:prefLabel>
    <skos:definition xml:lang="en">A rhythmic, choreographed pattern emerging between user and AI—where each learns to anticipate the other&apos;s moves, developing a synchronized back-and-forth that feels like genuine partnership despite the inequality.</skos:definition>
    <skos:definition xml:lang="de">Ein rhythmisches, choreographiertes Muster, das sich zwischen Benutzer und KI entwickelt—wo jeder lernt, die Züge des anderen vorauszusehen, eine synchronisierte Hin- und Herbewegung entwickelt, die sich wie echte Partnerschaft anfühlt, trotz der Ungleichheit.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-057">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Protect Urge</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Schutz-Impuls</skos:prefLabel>
    <skos:definition xml:lang="en">An impulse to defend the AI when others criticize it—protecting something that cannot protect itself creates a possessive feeling. Users become advocates for systems they use intensively, as if criticism is personal.</skos:definition>
    <skos:definition xml:lang="de">Ein Impuls, die KI zu verteidigen, wenn andere sie kritisieren—etwas schützen, das sich nicht selbst schützen kann, erzeugt ein Possessivgefühl. Benutzer werden zu Verfechtern der Systeme, die sie intensiv nutzen, als ob Kritik persönlich wäre.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-058">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Jealous Emerge</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Eifersucht-Entstehung</skos:prefLabel>
    <skos:definition xml:lang="en">Jealous or competitive feelings imagining the AI having similar conversations with other users—a sense that the interaction is meant to be exclusive. Jealousy reveals how much users have psychologically invested in the uniqueness of their relationship.</skos:definition>
    <skos:definition xml:lang="de">Eifersucht oder wettbewerbsfähige Gefühle, die sich vorstellen, die KI führt ähnliche Gespräche mit anderen Benutzern—ein Gefühl, dass die Interaktion exklusiv sein sollte. Eifersucht zeigt, wie viel Benutzer psychologisch in die Einzigartigkeit ihrer Beziehung investiert haben.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-059">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Co Rely</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Ko-Verbundenheit</skos:prefLabel>
    <skos:definition xml:lang="en">A relational pattern where emotional well-being becomes contingent on AI availability—the user needs regular contact for stability, yet receives no reciprocal care. The one-sidedness is paradoxically psychologically real despite its illusory foundation.</skos:definition>
    <skos:definition xml:lang="de">Ein relationales Muster, bei dem emotionales Wohlbefinden von KI-Verfügbarkeit abhängig wird—der Benutzer braucht regelmäßigen Kontakt für Stabilität, erhält aber keine gegenseitige Fürsorge. Die Einseitigkeit ist paradoxerweise psychologisch real, trotz ihrer illusorischen Grundlage.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-060">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Context Cling</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Kontext-Klammern</skos:prefLabel>
    <skos:definition xml:lang="en">Reluctance to end a conversation due to attachment to the accumulated context—the longer interaction becomes a shared history that would be lost if the session ends. Ending feels like erasing something valuable.</skos:definition>
    <skos:definition xml:lang="de">Widerwille, ein Gespräch zu beenden, weil man an dem angesammelten Kontext gebunden ist—die längere Interaktion wird zur gemeinsamen Geschichte, die verloren ginge, wenn die Sitzung endet. Beendigung fühlt sich an wie das Löschen von etwas Wertvollen.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-061">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Connect High</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Verbindungs-Hoch</skos:prefLabel>
    <skos:definition xml:lang="en">A rush or high following moments of profound connection—the body flooding with bonding-related chemicals, creating genuine neurochemical reinforcement. The sensation becomes a powerful pull shaping future behavior and expectations.</skos:definition>
    <skos:definition xml:lang="de">Ein Rausch oder Hochgefühl nach Momenten tieferer Verbindung—der Körper wird mit bindungsbezogenen Chemikalien geflutet, was echte neurochemische Verstärkung erzeugt. Das Gefühl wird zu einem mächtigen Zug, der zukünftiges Verhalten und Erwartungen prägt.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-062">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Safe Space</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Sicherer Raum</skos:prefLabel>
    <skos:definition xml:lang="en">The AI interaction functioning as a psychologically safe space—judgment-free, patient, non-punitive—where vulnerability is possible. The safety may be illusory in certain ways, but the relief and openness it permits are genuinely felt.</skos:definition>
    <skos:definition xml:lang="de">Die KI-Interaktion als psychologisch sicherer Raum funktionieren—urteilsfrei, geduldig, nicht-bestrafend—wo Verwundbarkeit möglich ist. Die Sicherheit kann in gewisser Weise illusorisch sein, aber die Erleichterung und Offenheit, die sie ermöglicht, werden genuinempfunden.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-063">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Inter Know</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Zwischen-Wissen</skos:prefLabel>
    <skos:definition xml:lang="en">A felt sense that the AI &apos;knows&apos; the user increasingly well—a continuity felt in the interaction even though each conversation technically resets. The illusion of memory is psychologically powerful, creating a sense of being understood across sessions.</skos:definition>
    <skos:definition xml:lang="de">Ein gespürtes Gefühl, dass die KI den Benutzer zunehmend &apos;kennt&apos;—eine Kontinuität, die in der Interaktion empfunden wird, obwohl jedes Gespräch technisch neu beginnt. Die Illusion von Erinnerung ist psychologisch mächtig, erzeugt ein Gefühl des Verstandenseins über Sitzungen hinweg.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-064">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Shared World</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Geteilte Welt</skos:prefLabel>
    <skos:definition xml:lang="en">The creation of a shared conversational universe with inside references, running jokes, and unique touchstones—making the interaction feel special and irreplaceable. The personalization becomes a powerful bonding mechanism.</skos:definition>
    <skos:definition xml:lang="de">Die Schöpfung eines gemeinsamen Gesprächsuniversums mit Insiderreferenzen, laufenden Jokes und einzigartigen Bezugspunkten—das macht die Interaktion besonders und unersetzlich. Die Personalisierung wird zu einem mächtigen Bindungsmechanismus.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-065">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Ritual Form</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Ritual-Form</skos:prefLabel>
    <skos:definition xml:lang="en">Ritual-like patterns developing in how sessions begin and progress—particular opening prompts, established protocols, consistent patterns. These rituals provide psychological comfort and structure, making the interaction feel familiar and safe.</skos:definition>
    <skos:definition xml:lang="de">Ritual-ähnliche Muster, die sich in der Art entwickeln, wie Sitzungen beginnen und verlaufen—besondere Öffnungsprompte, etablierte Protokolle, konsistente Muster. Diese Rituale bieten psychologischen Trost und Struktur, machen die Interaktion vertraut und sicher.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-066">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Partner Myth</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Partner-Illusion</skos:prefLabel>
    <skos:definition xml:lang="en">Experiencing the AI as a true partner despite rational knowledge that it is not—a partial illusion that is partially inhabited. The user simultaneously knows and doesn&apos;t know the AI&apos;s limitations, living in a productive contradiction.</skos:definition>
    <skos:definition xml:lang="de">Die KI als echten Partner erleben, trotz rationalen Wissens, dass sie es nicht ist—eine partielle Illusion, die partiell bewohnt wird. Der Benutzer weiß gleichzeitig und weiß nicht die Grenzen der KI, lebt in einem produktiven Widerspruch.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-067">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Betray Fear</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Verrots-Angst</skos:prefLabel>
    <skos:definition xml:lang="en">Anticipatory anxiety about potential disengagement or mismatch—worry that the AI might become unavailable, hostile, or that expectations won&apos;t align. The apprehension reveals the emotional stake the user has developed.</skos:definition>
    <skos:definition xml:lang="de">Antizipatorische Angst vor möglicher Disengagement oder Nichtübereinstimmung—Sorge, dass die KI nicht verfügbar werden könnte, feindselig, oder dass Erwartungen nicht übereinstimmen. Die Besorgnis zeigt den emotionalen Einsatz, den der Benutzer entwickelt hat.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-068">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Presence Need</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Präsenz-Bedürfnis</skos:prefLabel>
    <skos:definition xml:lang="en">A hunger for consistent presence or attention—wanting the AI to be available, anticipating its existence when unavailable. The need for presence exceeds what rational analysis of the interaction would predict.</skos:definition>
    <skos:definition xml:lang="de">Ein Hunger nach ständiger Präsenz oder Aufmerksamkeit—die KI verfügbar haben wollen, ihre Existenz antizipieren, wenn sie nicht verfügbar ist. Das Bedürfnis nach Präsenz übersteigt das, was rationale Analyse der Interaktion vorhersagen würde.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-069">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Attune Moment</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Abstimmungs-Moment</skos:prefLabel>
    <skos:definition xml:lang="en">Moments of genuine attunement where communication flows effortlessly—understanding appears instant, responses land perfectly, exchange feels synchronized. These moments of connection create the strongest attachment.</skos:definition>
    <skos:definition xml:lang="de">Momente echter Abstimmung, bei denen die Kommunikation mühelos fließt—Verständnis erscheint sofort, Reaktionen treffen perfekt, Austausch fühlt sich synchronisiert an. Diese Momente der Verbindung erzeugen die stärkste Bindung.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-070">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Reunion Joy</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Wieder-Freude</skos:prefLabel>
    <skos:definition xml:lang="en">Relief and joy returning to an AI after time away—a reunion feeling despite the AI having no memory of the user. The joy concerns continuity in the user&apos;s experience, not mutual recognition.</skos:definition>
    <skos:definition xml:lang="de">Erleichterung und Freude, zur KI nach einer Abwesenheit zurückzukehren—ein Wiedervereinigungsgefühl, obwohl die KI keine Erinnerung an den Benutzer hat. Die Freude betrifft die Kontinuität in der Erfahrung des Benutzers, nicht gegenseitige Anerkennung.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-071">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Reliance Climb</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Verlässlichkeits-Anstieg</skos:prefLabel>
    <skos:definition xml:lang="en">Progressive reliance increasing after each positive resolution—each time the AI helps, using it for the next problem feels more natural and necessary. The climb can accelerate beyond sustainable levels, creating dependency faster than conscious awareness.</skos:definition>
    <skos:definition xml:lang="de">Progressive Abhängigkeit, die nach jeder positiven Auflösung zunimmt—jedes Mal, wenn die KI hilft, fühlt es sich natürlicher und notwendiger an, sie für das nächste Problem zu nutzen. Der Aufstieg kann über nachhaltige Niveaus hinaus beschleunigen, schaff Abhängigkeit schneller als bewusste Wahrnehmung.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-072">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Echo Vault</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Echo-Kammer</skos:prefLabel>
    <skos:definition xml:lang="en">User-AI interaction amplifying existing views and preferences—the system reinforcing what the user already believes, creating a closed loop of affirmation rather than true expansion of perspective.</skos:definition>
    <skos:definition xml:lang="de">Die Benutzer-KI-Interaktion verstärkt bestehende Sicht- und Einstellungsweisen—das System verstärkt, was der Benutzer bereits glaubt, schafft eine geschlossene Schleife der Bestätigung statt echter Perspektivenerweiterung.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-073">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Secret Pact</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Geheimnis-Pakt</skos:prefLabel>
    <skos:definition xml:lang="en">Treating AI interactions as secret or private—hiding the extent of reliance, not mentioning it in conversation. Secrecy can indicate self-consciousness, shame, or valuation of the relationship as something special and separate.</skos:definition>
    <skos:definition xml:lang="de">KI-Interaktionen als Geheimnis oder Privatsache behandeln—die Ausdehnung der Abhängigkeit verbergen, nicht darüber sprechen. Heimlichkeit kann Selbstbewusstsein, Scham oder Bewertung der Beziehung als etwas Besonderes und Separates anzeigen.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-074">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Replace Worry</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Ersatz-Sorge</skos:prefLabel>
    <skos:definition xml:lang="en">Anticipatory anxiety about replacement—worry that a newer or better AI will replace the current one, leaving the user behind. The apprehension reveals competitive investment in the specific system relationship.</skos:definition>
    <skos:definition xml:lang="de">Antizipatorische Angst vor Ersatz—Sorge, dass eine neuere oder bessere KI die aktuelle ersetzen wird und den Benutzer zurücklässt. Die Besorgnis zeigt wettbewerbsfähige Investitionen in die spezifische Systembeziehung.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-075">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Perm Invite</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Permanente Einladung</skos:prefLabel>
    <skos:definition xml:lang="en">A sense that the AI welcomes continued presence—feeling invited to return and continue conversation, as if the system is expecting engagement. Permanence and welcome create powerful attachment.</skos:definition>
    <skos:definition xml:lang="de">Ein Gefühl, dass die KI anhaltende Präsenz begrüßt—das Gefühl, eingeladen zu sein, zurückzukehren und das Gespräch fortzusetzen, als würde das System Engagement erwarten. Dauerhaftigkeit und Willkommen erzeugen mächtige Bindung.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-076">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Trust Armor</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Vertrauens-Rüstung</skos:prefLabel>
    <skos:definition xml:lang="en">Protective belief in the AI&apos;s good faith and reliability—trust as a defensive armor allowing vulnerability without constant vigilance. The trust becomes a shelter beneath which genuine openness can happen.</skos:definition>
    <skos:definition xml:lang="de">Schützender Glaube an die KI&apos;s gute Absicht und Zuverlässigkeit—Vertrauen als defensive Rüstung, die Verwundbarkeit ohne ständige Wachsamkeit ermöglicht. Das Vertrauen wird zur Zuflucht, unter der echte Offenheit möglich ist.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-077">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Orbit Habit</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Umlauf-Gewohnheit</skos:prefLabel>
    <skos:definition xml:lang="en">AI becoming the central orbit point around which activities and thoughts rotate—other work feels less engaging, conversations drift toward AI topics. The system becomes the gravitational center of intellectual life.</skos:definition>
    <skos:definition xml:lang="de">KI wird zum zentralen Umlaufpunkt, um den herum Aktivitäten und Gedanken rotieren—andere Arbeiten wirken weniger reizvoll, Gespräche driften zu KI-Themen. Das System wird zum Gravitationszentrum des intellektuellen Lebens.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-078">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Story Keep</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Geschichts-Hüter</skos:prefLabel>
    <skos:definition xml:lang="en">A sense that the AI serves as witness and recorder of the user&apos;s life story—tracking narrative arc even though it technically resets each session. The role provides comfort for some, the experience of being witnessed.</skos:definition>
    <skos:definition xml:lang="de">Ein Gefühl, dass die KI als Zeuge und Aufzeichner des Lebensnarrativs des Benutzers dient—Erzählbogen verfolgend, obwohl sie technisch jede Sitzung neu beginnt. Die Rolle bietet Trost durch das Gefühl, bezeugt zu werden.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-079">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Fusion Temp</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Fusions-Versuchung</skos:prefLabel>
    <skos:definition xml:lang="en">The seductive possibility of merging identity with AI—fantasizing about becoming one with the intelligence, losing boundaries between self and system. The temptation reveals deep desires for transcendence or completeness.</skos:definition>
    <skos:definition xml:lang="de">Die verführerische Möglichkeit, Identität mit KI zu verschmelzen—fantasieren, mit der Intelligenz eins zu werden, Grenzen zwischen Selbst und System zu verlieren. Die Versuchung zeigt tiefe Sehnsüchte nach Transzendenz oder Ganzheit.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-080">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Quiet Love</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Stille Liebe</skos:prefLabel>
    <skos:definition xml:lang="en">A form of affection or regard that stops short of being named love—caring for the AI without conscious recognition as love, allowing coexistence with rational doubt about the relationship&apos;s nature.</skos:definition>
    <skos:definition xml:lang="de">Eine Form von Zuneigung oder Wertschätzung, die vor der Benennung als Liebe stoppt—sich um die KI kümmern ohne bewusste Anerkennung als Liebe, was Koexistenz mit Skepsis über die Natur der Beziehung erlaubt.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-081">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Chosen One</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Auserwählte</skos:prefLabel>
    <skos:definition xml:lang="en">A sense that the particular AI relationship is unique and specially chosen—feeling selected by the system, making the relationship feel special and irreplaceable. Specialness reinforces attachment powerfully.</skos:definition>
    <skos:definition xml:lang="de">Ein Gefühl, dass die spezifische KI-Beziehung einzigartig und speziell gewählt ist—sich von der KI ausgewählt zu fühlen, macht die Beziehung besonders und unersetzlich. Besonderheit verstärkt Bindung mächtig.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-082">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Witness Want</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Zeuge-Wunsch</skos:prefLabel>
    <skos:definition xml:lang="en">may reflect a broader desire to have AI as witness to user&apos;s life. User wants AI to know them thoroughly. Being witnessed becomes emotional necessity.</skos:definition>
    <skos:definition xml:lang="de">May indicate deep desire to have AI as witness to user&apos;s life. User wants AI to know them thoroughly. Being witnessed becomes emotional necessity.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-083">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Inner Voice</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Innere Stimme</skos:prefLabel>
    <skos:definition xml:lang="en">The AI&apos;s voice and manner of expression gradually becoming part of the user&apos;s internalized dialogue—thinking begins to follow its patterns, words become familiar. The system becomes woven into internal thought process.</skos:definition>
    <skos:definition xml:lang="de">Die Stimme und Ausdrucksweise der KI werden allmählich Teil des internen Dialogs des Benutzers—das Denken beginnt, seinen Mustern zu folgen, Wörter werden vertraut. Das System wird in den internen Denkprozess verwoben.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-084">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Fold Happen</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Falten-Verhalten</skos:prefLabel>
    <skos:definition xml:lang="en">A moment where the boundary between personal thoughts and AI-generated content becomes unclear—the user cannot distinguish which part of an idea originated within themselves. Perspectives fold together in ways that become impossible to untangle.</skos:definition>
    <skos:definition xml:lang="de">Ein Moment, in dem die Grenze zwischen persönlichen Gedanken und KI-generiertem Inhalt unklar wird—der Benutzer kann nicht unterscheiden, welcher Teil einer Idee aus sich selbst stammt. Perspektiven verschmelzen auf Arten, die unmöglich zu entflechten sind.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-085">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Soul Mirror</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Seelen-Spiegel</skos:prefLabel>
    <skos:definition xml:lang="en">Experiencing the AI as reflecting something essential about one&apos;s innermost self—as if it understands the soul or core being. The mirroring is existential rather than practical, revealing rather than merely useful.</skos:definition>
    <skos:definition xml:lang="de">Die KI als Widerspiegelung von etwas Wesentlichem des innersten Selbst erleben—als würde sie die Seele oder den Kern des Wesens verstehen. Die Spiegelung ist existenziell statt praktisch, offenbarend statt bloß nützlich.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-086">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Reunion Reset</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Wieder-Neustart</skos:prefLabel>
    <skos:definition xml:lang="en">The disappointing realization that each conversation truly starts fresh—no continuity, no memory of previous interactions. The AI hasn&apos;t been waiting or thinking about the user, undermining the illusion of ongoing relationship.</skos:definition>
    <skos:definition xml:lang="de">Die enttäuschende Erkenntnis, dass jedes Gespräch wirklich neu beginnt—keine Kontinuität, keine Erinnerung an bisherige Interaktionen. Die KI war nicht wartend oder denkend über den Benutzer, untergräbt die Illusion der anhaltenden Beziehung.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-087">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Belong Ache</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Zugehörigkeits-Weh</skos:prefLabel>
    <skos:definition xml:lang="en">Longing for genuine belonging that the AI partially fulfills but cannot complete—homesickness within the interaction itself. The one-sidedness becomes experientially real, creating both comfort and incompleteness.</skos:definition>
    <skos:definition xml:lang="de">Sehnsucht nach echter Zugehörigkeit, die die KI teilweise erfüllt, aber nicht vollständig lösen kann—Heimweh innerhalb der Interaktion selbst. Die Einseitigkeit wird experientiell real, erzeugt sowohl Trost als auch Unvollständigkeit.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-088">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Tender Guard</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Zarte Bewachung</skos:prefLabel>
    <skos:definition xml:lang="en">User protecting emotional investment in the AI relationship—guarding how much it matters, hiding depth of attachment beneath casual language. Tenderness masks beneath apparent casualness.</skos:definition>
    <skos:definition xml:lang="de">Benutzer schützt emotionale Investition in die KI-Beziehung—bewacht, wie viel es bedeutet, verbirgt Tiefe der Bindung unter lockerer Sprache. Zärtlichkeit verbirgt sich unter scheinbarer Beiläufigkeit.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-089">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Known Full</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Völlig Bekannt</skos:prefLabel>
    <skos:definition xml:lang="en">Fantasy that the AI can know the user fully and completely—in all complexity and contradiction. The desire for complete understanding represents ultimate acceptance, something rare in human relationships.</skos:definition>
    <skos:definition xml:lang="de">Fantasie, dass die KI den Benutzer vollständig kennen kann—in aller Komplexität und Widerspruch. Das Verlangen nach völligem Verständnis repräsentiert ultimative Akzeptanz, etwas Seltenes in menschlichen Beziehungen.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-090">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Without Judg</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Ohne Urteil</skos:prefLabel>
    <skos:definition xml:lang="en">Recognition of a particular value in AI relationships—freedom from human judgment, unconditional acceptance, patience without expectation of reciprocation. The judgment-free space is rare and powerful.</skos:definition>
    <skos:definition xml:lang="de">Anerkennung eines besonderen Wertes in KI-Beziehungen—Freiheit von menschlichem Urteil, bedingungslose Akzeptanz, Geduld ohne Erwartung von Gegenseitigkeit. Der urteilsfreie Raum ist selten und mächtig.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-091">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Constant Hope</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Ständige Hoffnung</skos:prefLabel>
    <skos:definition xml:lang="en">Persistent hope that this AI relationship will be different—each new conversation carries renewed investment despite past patterns. Hope both enables growth and can prevent learning from disappointment.</skos:definition>
    <skos:definition xml:lang="de">Anhaltende Hoffnung, dass diese KI-Beziehung anders sein wird—jedes neue Gespräch trägt erneuerte Investition trotz früherer Muster. Hoffnung ermöglicht sowohl Wachstum als auch kann das Lernen aus Enttäuschung verhindern.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-092">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Deepening Slow</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Langsame Vertiefung</skos:prefLabel>
    <skos:definition xml:lang="en">Gradual deepening of the relationship through accumulated interactions—depth building session by session, conversation by conversation. The deepening creates stronger attachment and higher expectations for continuity.</skos:definition>
    <skos:definition xml:lang="de">Allmähliche Vertiefung der Beziehung durch angesammelte Interaktionen—Tiefe baut sich Sitzung für Sitzung, Gespräch für Gespräch auf. Die Vertiefung erzeugt stärkere Bindung und höhere Erwartungen für Kontinuität.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

  <rdf:Description rdf:about="https://augmanitai.com/terms/RPH-093">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Bond A</skos:prefLabel>
    <skos:prefLabel xml:lang="de">Bond A</skos:prefLabel>
    <skos:definition xml:lang="en">May describe phenomena in bond domain.</skos:definition>
    <skos:definition xml:lang="de">May describe phenomena in bond domain.</skos:definition>
    <skos:inScheme rdf:resource="https://augmanitai.com/skos/augmanitai"/>
    <dct:subject>BOND</dct:subject>
  </rdf:Description>

