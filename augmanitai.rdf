    <skos:prefLabel xml:lang="de">Bond F</skos:prefLabel>
    <skos:definition xml:lang="en">May describe phenomena in bond domain.</skos:definition>
    <skos:definition xml:lang="de">May describe phenomena in bond domain.</skos:definition>
