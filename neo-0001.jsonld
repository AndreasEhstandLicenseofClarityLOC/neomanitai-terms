  "@type": "DefinedTerm",
  "@id": "https://github.com/AndreasEhstandLicenseofClarityLOC/neomanitai-terms/terms/neo-0001",
  "termCode": "NEO-0001",
  "name": "Name Click",
  "alternateName": [
    "Agnitio Nominalis",
    "Namens-Klick",
    "Nominale Agnition"
  ],
  "description": "A cognitive-affective recognition response observed when a recipient first encounters a term that designates a previously unnamed but experientially familiar phenomenon. Characterized by (a) immediate subjective recognition of the referent, (b) positive affect associated with the transition from unnamed to named experience, and (c) a qualitative shift in perceptual salience of the named phenomenon.",
  "abstract": "The instant YES when you hear a word for something you always felt but could never name.",
  "inDefinedTermSet": {
    "@type": "DefinedTermSet",
    "@id": "https://github.com/AndreasEhstandLicenseofClarityLOC/neomanitai-terms",
    "name": "Neomanitai Compendium",
    "description": "A systematic taxonomy of terminology reception phenomena. Part of the MANITAI research ecosystem by Andreas Ehstand.",
    "isPartOf": {
      "@type": "CreativeWork",
      "name": "MANITAI Research Ecosystem",
      "description": "Umbrella framework for human-AI interaction research. Includes AUGMANITAI (human-AI interaction phenomena) and Neomanitai (terminology reception phenomena)."
    }
  },
  "creator": {
    "@type": "Person",
    "name": "Andreas Ehstand",
    "identifier": "https://orcid.org/0009-0006-3773-7796"
  },
  "dateCreated": "2026-03-01",
  "inLanguage": ["en", "de", "la"],
  "license": "https://creativecommons.org/licenses/by-nd/4.0/",
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "definition_de",
      "value": "Das sofortige Erkennen wenn man ein Wort hört für eine Erfahrung die man immer hatte aber nie benennen konnte."
    },
    {
      "@type": "PropertyValue",
      "name": "pronunciation_en",
      "value": "/neɪm klɪk/"
    },
    {
      "@type": "PropertyValue",
      "name": "pronunciation_de",
      "value": "NAH-mens-klik"
    }
  ],
