  "@type": "DefinedTerm",
  "@id": "https://github.com/AndreasEhstandLicenseofClarityLOC/neomanitai-terms/terms/neo-0002",
  "termCode": "NEO-0002",
  "name": "Label Flash",
  "alternateName": [
    "Fulgor Designationis",
    "Begriffsblitz",
    "Designatorischer Fulgor"
  ],
  "description": "A pre-semantic perceptual response occurring in the initial milliseconds of exposure to a novel term, prior to lexical access and meaning construction. Characterized by (a) sub-semantic processing of the term as visual or auditory gestalt before meaning is accessed, (b) attentional capture triggered by novel orthographic or phonological patterns, and (c) evaluative priming carrying implicit valence based on the term's surface properties.",
  "abstract": "That split-second strobe when a new word hits your eyes before meaning catches up.",
  "inDefinedTermSet": {
    "@type": "DefinedTermSet",
    "@id": "https://github.com/AndreasEhstandLicenseofClarityLOC/neomanitai-terms",
    "name": "Neomanitai Compendium",
    "description": "A systematic taxonomy of terminology reception phenomena. Part of the MANITAI research ecosystem by Andreas Ehstand.",
    "isPartOf": {
      "@type": "CreativeWork",
      "name": "MANITAI Research Ecosystem",
      "description": "Umbrella framework for human-AI interaction research. Includes AUGMANITAI (human-AI interaction phenomena) and Neomanitai (terminology reception phenomena)."
    }
  },
  "creator": {
    "@type": "Person",
    "name": "Andreas Ehstand",
    "identifier": "https://orcid.org/0009-0006-3773-7796"
  },
  "dateCreated": "2026-03-02",
  "inLanguage": ["en", "de", "la"],
  "license": "https://creativecommons.org/licenses/by-nd/4.0/",
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "definition_de",
      "value": "Der Sekundenbruchteil-Impakt wenn ein neues Wort die Aufmerksamkeit fängt bevor seine Bedeutung verarbeitet wird."
    },
    {
      "@type": "PropertyValue",
      "name": "pronunciation_en",
      "value": "/ˈleɪbəl flæʃ/"
    },
    {
      "@type": "PropertyValue",
      "name": "pronunciation_de",
      "value": "beh-GRIFFS-blitz"
    }
  ],
