  "@type": "DefinedTerm",
  "@id": "https://github.com/AndreasEhstandLicenseofClarityLOC/neomanitai-terms/terms/neo-0003",
  "termCode": "NEO-0003",
  "name": "Clarity Cascade",
  "alternateName": [
    "Cascada Lucis",
    "Klarheitskaskade",
    "Kaskade der Klarheit"
  ],
  "description": "A post-nominal cognitive reorganization event in which the acquisition of a single term triggers rapid, multi-domain restructuring of previously unconnected experiential data. Characterized by (a) retroactive coherence — previously disconnected memories and observations become retroactively intelligible as instances of the newly named phenomenon, (b) pattern amplification — the named phenomenon becomes perceptually salient across multiple life domains simultaneously, (c) communicative unlocking — experiences that were previously inarticulable become shareable, and (d) cascading connectivity — the insight propagates beyond the original domain into adjacent conceptual territories.",
  "abstract": "The waterfall of sudden understanding that pours through you once a single word unlocks an entire pattern.",
  "inDefinedTermSet": {
    "@type": "DefinedTermSet",
    "@id": "https://github.com/AndreasEhstandLicenseofClarityLOC/neomanitai-terms",
    "name": "Neomanitai Compendium",
    "description": "A systematic taxonomy of terminology reception phenomena. Part of the MANITAI research ecosystem by Andreas Ehstand.",
    "isPartOf": {
      "@type": "CreativeWork",
      "name": "MANITAI Research Ecosystem",
      "description": "Umbrella framework for human-AI interaction research. Includes AUGMANITAI (human-AI interaction phenomena) and Neomanitai (terminology reception phenomena)."
    }
  },
  "creator": {
    "@type": "Person",
    "name": "Andreas Ehstand",
    "identifier": "https://orcid.org/0009-0006-3773-7796"
  },
  "dateCreated": "2026-03-02",
  "inLanguage": ["en", "de", "la"],
  "license": "https://creativecommons.org/licenses/by-nd/4.0/",
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "definition_de",
      "value": "Der Wasserfall plötzlichen Verstehens der durch dich hindurchströmt wenn ein einziges Wort ein ganzes Muster aufschließt."
    },
    {
      "@type": "PropertyValue",
