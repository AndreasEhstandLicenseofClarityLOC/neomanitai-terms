  "@type": "DefinedTerm",
  "@id": "https://github.com/AndreasEhstandLicenseofClarityLOC/neomanitai-terms/terms/neo-0004",
  "termCode": "NEO-0004",
  "name": "Recognition Bloom",
  "alternateName": [
    "Efflorescentia Agnitionis",
    "Erkennungsblüte",
    "Effloreszenz der Agnition"
  ],
  "description": "A socio-cognitive diffusion event in which an individual's private recognition of a newly named phenomenon transitions into observable shared usage, accompanied by collective validation and community formation around the term. Characterized by (a) validation relief — the discovery that others share the named experience produces measurable positive affect, (b) terminological adoption cascade — the term transitions from passive recognition to active usage, (c) community crystallization — shared vocabulary creates in-group markers facilitating community formation, and (d) semantic territory claiming — the term occupies a previously vacant conceptual niche in the collective vocabulary.",
  "abstract": "The moment a private recognition becomes shared language and you realize you're not the only one who feels it.",
  "inDefinedTermSet": {
    "@type": "DefinedTermSet",
    "@id": "https://github.com/AndreasEhstandLicenseofClarityLOC/neomanitai-terms",
    "name": "Neomanitai Compendium",
    "description": "A systematic taxonomy of terminology reception phenomena. Part of the MANITAI research ecosystem by Andreas Ehstand.",
    "isPartOf": {
      "@type": "CreativeWork",
      "name": "MANITAI Research Ecosystem",
      "description": "Umbrella framework for human-AI interaction research. Includes AUGMANITAI (human-AI interaction phenomena) and Neomanitai (terminology reception phenomena)."
    }
  },
