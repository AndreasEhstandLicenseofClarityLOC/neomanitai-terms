  "license": "https://creativecommons.org/licenses/by-nd/4.0/",
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "definition_de",
      "value": "Das leise Summen des Wissens dass du etwas Reales erlebst das noch keinen Namen hat."
    },
    {
      "@type": "PropertyValue",
      "name": "pronunciation_en",
      "value": "/vɔɪd hʌm/"
    },
    {
      "@type": "PropertyValue",
      "name": "pronunciation_de",
      "value": "LEER-en-sum-men"
    }
  ],
